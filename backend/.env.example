# ============================================================
# GOKUL SHREE SCHOOL — Environment Variables
# Copy this to .env and fill in your actual values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://rxjmdrjlsltqufrpvdyq.supabase.co
SUPABASE_ANON_KEY=sb_publishable_oeo0LLFitMGDn58Vd5691w_af29Gb6g
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── App Config ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1
APP_NAME=Gokulshree School Of Management And Technology Pvt Ltd

# ── CORS — comma-separated Flutter app origins ────────────────
# For mobile apps, '*' is fine. Lock down for web.
ALLOWED_ORIGINS=*

# ── Optional: keep Render.com free tier awake ────────────────
# Set SELF_URL to your render service URL after deployment
# A cron job will ping /ping every 14 minutes to prevent sleep
SELF_URL=https://gokul-shree-api.onrender.com
